# RedTeam Server Environment Variables
# Скопировать в .env и заполнить

# Bind settings (Tailscale IP — доступ только из VPN)
BIND_IP=YOUR_TAILSCALE_IP
BIND_PORT=5100

# Zabbix
ZABBIX_URL=http://YOUR_TAILSCALE_IP:8081
ZABBIX_API_URL=http://YOUR_TAILSCALE_IP:8081/api_jsonrpc.php
ZABBIX_USER=Admin
ZABBIX_PASSWORD=your-zabbix-password

# Headscale credentials (для генерации образов)
HEADSCALE_SERVER=headscale.example.com
HEADSCALE_USER=root
HEADSCALE_PASSWORD=your-password-here
